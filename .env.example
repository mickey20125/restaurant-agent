# Google Maps（必填）
GOOGLE_MAPS_API_KEY=PUT_YOUR_REAL_KEY_HERE

# Brave Search API（Threads 搜尋用，必填）
# 免費 2000 次/月，申請：https://api.search.brave.com
BRAVE_SEARCH_API_KEY=PUT_YOUR_BRAVE_KEY_HERE

# Maps API 保護（選填）
MAPS_DAILY_CALL_LIMIT=100
MAPS_CACHE_TTL_SECONDS=86400
AGENT_DAILY_USAGE_PATH=.cache/agent_daily_usage.json
AGENT_SKILL_CACHE_PATH=.cache/agent_skill_cache.json

# Threads 搜尋（選填）
THREADS_ENABLED=true
THREADS_DAILY_CALL_LIMIT=50
THREADS_CACHE_TTL_SECONDS=3600
BRAVE_MONTHLY_LIMIT=2000
