# Google Maps（必填）
GOOGLE_MAPS_API_KEY=PUT_YOUR_REAL_KEY_HERE

# Google Custom Search（Threads 搜尋用，必填）
# 需另建一把普通 API Key（非 Maps Platform），在 API restrictions 只勾 Custom Search API
# 詳細步驟：THREADS_SEARCH_GUIDE.md
GOOGLE_SEARCH_API_KEY=PUT_YOUR_SEARCH_KEY_HERE
GOOGLE_SEARCH_CX=your_search_engine_id_here

# Maps API 保護（選填）
MAPS_DAILY_CALL_LIMIT=100
MAPS_CACHE_TTL_SECONDS=86400
AGENT_DAILY_USAGE_PATH=.cache/agent_daily_usage.json
AGENT_SKILL_CACHE_PATH=.cache/agent_skill_cache.json

